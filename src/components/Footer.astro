---
import { SITE, SOCIALS } from '../config';

const nav = [
  { label: 'Work',           href: '/work' },
  { label: 'Process',        href: '/#process' },
  { label: 'Contact',        href: '/#contact' },
  { label: 'Privacy Policy', href: '/privacy-policy' },
];
---

<footer class="bg-primary">
  <div class="max-w-[1440px] mx-auto px-5 md:px-16 pt-16 pb-10">

    <!-- Top row: brand (left) + editorial statement (right) -->
    <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-10 pb-12 footer-divider">

      <!-- Brand -->
      <div class="flex flex-col gap-3">
        <span class="font-serif text-[22px] font-normal text-cream tracking-[0.5px]">
          {SITE.name}
        </span>
        <p class="font-sans text-[13px] footer-muted">
          Automation, design, and AI for complex operations.
        </p>
      </div>

      <!-- Editorial closing statement -->
      <p class="font-serif font-light footer-statement md:text-right" style="font-size: clamp(1.25rem, 1.5vw, 1.75rem); line-height: 1.2; letter-spacing: -0.01em; color: rgba(245,240,232,0.65);">
        Built for operations that demand more.
      </p>

    </div>

    <!-- Bottom strip: nav links (left) + copyright + LinkedIn (right) -->
    <div class="flex flex-col md:flex-row md:justify-between md:items-center gap-4 pt-8">

      <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
        {nav.map((link) => (
          <a href={link.href} class="font-sans text-[13px] footer-link">{link.label}</a>
        ))}
      </div>

      <div class="flex items-center gap-6">
        <p class="font-sans text-[13px] footer-label">© 2026 {SITE.legalName}</p>
        <a
          href={SOCIALS.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="footer-social"
        >
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zm.02 4.5h-5v16h5v-16zm7.982 0h-4.968v16h4.969v-8.399c0-4.67 6.029-5.052 6.029 0v8.399h4.988v-10.131c0-7.88-8.922-7.593-11.018-3.714v-2.155z"/>
          </svg>
        </a>
      </div>

    </div>
  </div>
</footer>

<style>
  .footer-divider {
    border-bottom: 0.5px solid rgba(245, 240, 232, 0.15);
  }
  .footer-label {
    color: rgba(245, 240, 232, 0.55);
  }
  .footer-muted {
    color: rgba(245, 240, 232, 0.55);
  }
  .footer-link {
    color: rgba(245, 240, 232, 0.55);
    transition: color 0.2s ease;
  }
  .footer-link:hover {
    color: rgba(245, 240, 232, 1);
  }
  .footer-social {
    color: rgba(245, 240, 232, 0.55);
    transition: color 0.2s ease;
  }
  .footer-social:hover {
    color: rgba(245, 240, 232, 0.9);
  }
</style>
