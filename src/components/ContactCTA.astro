---
import { CAL_LINK, CAL_NAMESPACE, CAL_CONFIG } from '../config';

const stats = [
  { value: 20, suffix: '+', label: 'Years in enterprise systems' },
  { value: 4,  suffix: 'wk', label: 'Average delivery' },
  { value: 100, suffix: '%', label: 'USA-focused · CR-based' },
];
---

<section id="contact" class="bg-cream px-5 md:px-16 py-24 flex flex-col items-start" style="border-bottom: 0.5px solid #E7E1D6;">

  <span class="eyebrow text-navy/60 block mb-6">Let's work together</span>

  <h2 class="font-serif text-[32px] md:text-[48px] text-navy max-w-2xl mb-8 leading-tight">
    Your firm deserves systems that actually work.
  </h2>

  <p class="font-sans text-[17px] leading-relaxed max-w-xl mb-10" style="color: rgba(30, 42, 56, 0.8);">
    We take on 2–3 new clients per quarter. If the fit is right, we move fast.
  </p>

  <div class="flex flex-col gap-6 items-start">
    <button
      data-cal-link={CAL_LINK}
      data-cal-namespace={CAL_NAMESPACE}
      data-cal-config={CAL_CONFIG}
      class="bg-navy text-cream px-8 py-4 font-sans text-[13px] font-medium tracking-wide hover:opacity-90 transition-opacity uppercase cursor-pointer"
    >
      Book a discovery call
    </button>
  </div>

  <!-- Social proof strip -->
  <div class="mt-16 w-full">
    <div class="grid grid-cols-1 md:grid-cols-3 w-full">
      {stats.map((stat, i) => (
        <div
          class:list={[
            'flex flex-col items-start md:items-center justify-center pt-8 pb-6 gap-1 group cursor-default',
            i < stats.length - 1 ? 'border-b md:border-b-0' : '',
          ]}
          style={`border-top: 0.5px solid rgba(30,42,56,0.1); border-right: 0.5px solid rgba(30,42,56,0.1); border-bottom: 0.5px solid rgba(30,42,56,0.1);${i === 0 ? ' border-left: 0.5px solid rgba(30,42,56,0.1);' : ''}`}
        >
          <span
            class="font-serif font-light text-navy leading-none select-none transition-colors duration-300 group-hover:text-accent"
            style="font-size: clamp(2rem, 3.5vw, 3.25rem); letter-spacing: -0.03em;"
            data-count={stat.value}
            data-suffix={stat.suffix}
          >0{stat.suffix}</span>
          <span class="eyebrow text-navy/50 group-hover:text-navy/80 transition-colors duration-300 mt-1">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>

  <script>
    const counters = document.querySelectorAll<HTMLElement>('[data-count]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.count ?? '0', 10);
        const suffix = el.dataset.suffix ?? '';
        const duration = 1200;
        const start = performance.now();
        const tick = (now: number) => {
          const progress = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.round(ease * target) + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
        observer.unobserve(el);
      });
    }, { threshold: 0.4 });

    counters.forEach(el => observer.observe(el));
  </script>

</section>
