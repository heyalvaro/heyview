---
import { CAL_LINK, CAL_CONFIG } from '../config';

const steps = [
  {
    number: '01',
    title: 'Discovery',
    body: "We map how the work actually happens, not how the org chart says it happens. Expect uncomfortable questions.",
  },
  {
    number: '02',
    title: 'Strategy',
    body: "You get a written plan: what we'll build, what it replaces, and a fixed quote. You know the full cost before we write a line of code.",
  },
  {
    number: '03',
    title: 'Execution',
    body: "We build it. You see progress every week, on the real system, not in slides.",
  },
  {
    number: '04',
    title: 'Handoff',
    body: "You own everything: documented, transferred, explained. If we did our job, you don't need us afterward.",
  },
];
---

<section id="process" class="grain bg-cream px-5 md:px-16 py-24"
  style="border-bottom: 0.5px solid #E7E1D6;">

  <span class="eyebrow text-navy/60 block mb-6">Our process</span>

  <h2 class="font-serif text-[32px] md:text-[40px] text-navy font-normal mb-20 leading-tight">
    Four stages. No surprises.
  </h2>

  <div class="relative">
    <!-- Timeline rule: vertical on mobile, horizontal on desktop -->
    <div class="absolute bg-cream-border left-[5px] top-0 bottom-0 w-px md:left-0 md:top-[5px] md:bottom-auto md:w-full md:h-px"></div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8 relative z-10">
      {steps.map((step) => (
        <div class="flex flex-row md:flex-col gap-6 md:gap-0">

          <!-- Timeline dot -->
          <div class="flex-shrink-0 w-3 md:w-full h-auto md:h-3 flex items-start md:items-center justify-center md:justify-start">
            <div class="w-[11px] h-[11px] rounded-full bg-accent ring-2 ring-cream mt-0.5 md:mt-0"></div>
          </div>

          <!-- Step content -->
          <div class="pt-0 md:pt-10 flex-1">
            <span
              class="font-serif text-[52px] text-accent leading-none font-normal block mb-3 select-none transition-colors duration-300 group hover:text-accent/80"
              data-count={parseInt(step.number)}
              data-suffix=""
              style="cursor: default;"
            >
              {step.number}
            </span>
            <h3 class="font-serif text-[22px] text-navy font-normal mb-2">{step.title}</h3>
            <p class="font-sans text-[13px] text-navy/70 leading-relaxed">{step.body}</p>
          </div>

        </div>
      ))}
    </div>
  </div>

  <div class="flex justify-center mt-20">
    <button
      data-cal-link={CAL_LINK}
      data-cal-config={CAL_CONFIG}
      class="bg-navy text-cream px-8 py-4 font-sans text-[13px] font-medium tracking-wide hover:opacity-90 transition-opacity uppercase cursor-pointer"
    >
      Book a discovery call
    </button>
  </div>

  <script is:inline>
    const counters = document.querySelectorAll('[data-count]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        const target = parseInt(el.dataset.count ?? '0', 10);
        const suffix = el.dataset.suffix ?? '';
        const duration = 1200;
        const start = performance.now();
        const tick = (now) => {
          const progress = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - progress, 3);
          const padded = String(Math.round(ease * target)).padStart(2, '0');
          el.textContent = padded + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
        observer.unobserve(el);
      });
    }, { threshold: 0.4 });

    counters.forEach(el => observer.observe(el));
  </script>

</section>
