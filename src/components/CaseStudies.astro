---
import { getCollection } from 'astro:content';
import WorkCard from './WorkCard.astro';

// Single source of truth: projects live in src/content/work/*.md.
const projects = (await getCollection('work', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);

const featured = projects.find((p) => p.data.featured) ?? projects[0];
const sideProjects = projects.filter((p) => p.id !== featured?.id).slice(0, 2);
---

<section id="projects" class="bg-navy px-5 md:px-16 py-24">

  <div class="flex justify-between items-end mb-16">
    <div>
      <span class="eyebrow text-accent-green block mb-6">Selected Work</span>
      <h2 class="font-serif text-[32px] md:text-[40px] text-cream font-normal">The work.</h2>
    </div>
    <a href="/work" class="font-sans text-[13px] text-muted-soft hover:text-cream transition-colors whitespace-nowrap">
      View all work →
    </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">

    <!-- Featured project — 8 cols -->
    {featured && <WorkCard project={featured} variant="featured" class="col-span-1 md:col-span-8" />}

    <!-- Side projects — 4 cols -->
    <div class="col-span-1 md:col-span-4 flex flex-col gap-6">
      {sideProjects.map((project) => <WorkCard project={project} variant="compact" class="flex-1" />)}
    </div>

  </div>

</section>
