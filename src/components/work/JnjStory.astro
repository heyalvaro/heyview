---
// Problem statement
const problemBody = `After the Shockwave Medical acquisition, J&J MedTech's manufacturing teams were planning capacity across two sites in a 350MB Excel file with 143 worksheets — so large that it could barely be opened and every calculation took 5 minutes. Six departments each kept their own tabs with no shared data model, and every planner was losing 15–20 hours per week just keeping the spreadsheet alive. The team needed to model 20+ medical device products across a five-year planning horizon and account for yield ramps and operator learning curves — none of which the Excel model could scale to handle.`;


// Solution approach with features
const solutionIntro = "Before any software, every screen was wireframed by hand and reviewed with the people who'd actually use it — agreeing exactly what each one had to answer before a line was built. The planners signed off once, and the finished system matched the sketch without a single layout debate.";

const solutionFeatures = [
  {
    title: "Designed before building",
    body: "Hand-drawn wireframes validated with end users ensured the final system matched stakeholder expectations exactly."
  },
  {
    title: "Built in three weeks",
    body: "From sketch to live dashboard with an automated model pulling every team's inputs, calculating instantly, and syncing with J&J's fiscal calendar."
  },
  {
    title: "Runs on tools they owned",
    body: "Built on Microsoft Power Platform so there was nothing new to license or learn from scratch."
  }
];

---

<!-- THE PROBLEM (Context Section) -->
<section class="bg-surface text-primary" style="border-top: 0.5px solid #E7E1D6; border-bottom: 0.5px solid #E7E1D6;">
  <div class="max-w-360 mx-auto px-5 md:px-16 py-20 md:py-28 grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10">
    <div class="md:col-span-4">
      <h2 class="font-serif text-[32px] md:text-[40px] text-primary font-normal leading-tight">
        The Context
      </h2>
    </div>
    <div class="md:col-span-7 md:col-start-6">
      <p class="font-sans text-[17px] md:text-[20px] leading-relaxed text-secondary max-w-2xl">
        {problemBody}
      </p>
    </div>
  </div>
</section>

<!-- THE SOLUTION -->
<section class="bg-navy" style="color: #F5F0E8;">
  <div class="max-w-360 mx-auto px-5 md:px-16 py-20 md:py-28 grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10">
    <!-- Left: heading + intro -->
    <div class="md:col-span-5">
      <h2 class="font-serif text-[32px] md:text-[40px] text-cream font-normal leading-tight mb-6">
        The Solution
      </h2>
      <p class="font-sans text-[17px] md:text-[20px] leading-relaxed" style="color: rgba(245,240,232,0.65);">
        {solutionIntro}
      </p>
    </div>

    <!-- Right: feature list with dots and connectors -->
    <div class="md:col-span-6 md:col-start-7 space-y-12">
      {solutionFeatures.map((feature, idx) => (
        <div class="group relative pl-12">
          <div class="absolute left-0 top-2 w-4 h-4 rounded-full" style="background-color: #A67C52;"></div>
          {idx < solutionFeatures.length - 1 && (
            <div class="absolute left-2 top-6 w-[0.5px] h-full" style="background-color: rgba(245,240,232,0.1);"></div>
          )}
          <h3 class="font-serif text-[22px] text-cream mb-3 font-normal leading-snug">
            {feature.title}
          </h3>
          <p class="font-sans text-[15px] leading-relaxed" style="color: rgba(245,240,232,0.65);">
            {feature.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

