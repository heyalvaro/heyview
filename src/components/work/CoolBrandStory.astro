---
const problemBody = `CoolBrand CR is a luxury consignment boutique in Costa Rica — collector watches, fine jewelry, premium handbags, items that can be worth tens of thousands of dollars. Their Shopify site had consistent organic traffic. What it didn't have was a single inquiry. The design felt generic: visually misaligned with the luxury positioning the brand was going for, a cluttered layout with inconsistent category structure, and a standard checkout flow that made no sense for high-value items where customers want to talk before committing. Traffic without conversion is a design problem, not an SEO problem.`;

const solutionIntro = "The redesign started from a single insight: for luxury consignment, the shopping cart is the wrong interface. Customers need to ask about condition, provenance, and pricing before committing. Every layout decision — from the aesthetic to the conversion path — followed from that.";

const solutionFeatures = [
  {
    title: "A dark editorial aesthetic",
    body: "Dark backgrounds, gold accent typography, high-contrast hero imagery — a layout that reads like a collector's magazine, not a commodity store. Chosen to signal exclusivity and brand authority, not just style."
  },
  {
    title: "WhatsApp as the primary CTA",
    body: "A floating WhatsApp button persistent across every page, plus a per-product inquiry CTA above any cart option. One tap from browse to conversation — regardless of where the customer is in the site."
  },
  {
    title: "An architecture that reflects the business",
    body: "New section hierarchy matching how CoolBrand's customers actually shop and how the business actually works: editorial collection entry points, consignment intake surfaced prominently, and an inquiry capture for customers searching for specific pieces."
  }
];
---

<!-- THE CONTEXT -->
<section class="bg-surface text-primary" style="border-top: 0.5px solid #E7E1D6; border-bottom: 0.5px solid #E7E1D6;">
  <div class="max-w-360 mx-auto px-5 md:px-16 py-20 md:py-28 grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10">
    <div class="md:col-span-4">
      <h2 class="font-serif text-[32px] md:text-[40px] text-primary font-normal leading-tight">
        The Context
      </h2>
    </div>
    <div class="md:col-span-7 md:col-start-6">
      <p class="font-sans text-[17px] md:text-[20px] leading-relaxed text-secondary max-w-2xl">
        {problemBody}
      </p>
    </div>
  </div>
</section>

<!-- THE SOLUTION -->
<section class="bg-navy" style="color: #F5F0E8;">
  <div class="max-w-360 mx-auto px-5 md:px-16 py-20 md:py-28 grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10">
    <div class="md:col-span-5">
      <h2 class="font-serif text-[32px] md:text-[40px] text-cream font-normal leading-tight mb-6">
        The Solution
      </h2>
      <p class="font-sans text-[17px] md:text-[20px] leading-relaxed" style="color: rgba(245,240,232,0.65);">
        {solutionIntro}
      </p>
    </div>

    <div class="md:col-span-6 md:col-start-7 space-y-12">
      {solutionFeatures.map((feature, idx) => (
        <div class="group relative pl-12">
          <div class="absolute left-0 top-2 w-4 h-4 rounded-full" style="background-color: #A67C52;"></div>
          {idx < solutionFeatures.length - 1 && (
            <div class="absolute left-2 top-6 w-[0.5px] h-full" style="background-color: rgba(245,240,232,0.1);"></div>
          )}
          <h3 class="font-serif text-[22px] text-cream mb-3 font-normal leading-snug">
            {feature.title}
          </h3>
          <p class="font-sans text-[15px] leading-relaxed" style="color: rgba(245,240,232,0.65);">
            {feature.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
