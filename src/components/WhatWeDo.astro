---
const services = [
  {
    number: ‘01’,
    title: ‘Document & process automation’,
    body: ‘If three people and two days go into a document that runs your business, that’s not a process. That’s a problem with a routine. We automate the manual workflows that quietly slow a business.’,
  },
  {
    number: ‘02’,
    title: ‘Customer communication & AI assistants’,
    body: ‘Your customers write at 9 PM on WhatsApp, Instagram, and email — and they buy from whoever answers first. We build AI assistants that respond instantly, book the appointment, and win back the ones who went quiet.’,
  },
  {
    number: ‘03’,
    title: ‘Operations dashboards’,
    body: ‘Reports tell you what happened. We build dashboards that tell you what to do next — designed for the person making the decision, not the person exporting the CSV.’,
  },
  {
    number: ‘04’,
    title: ‘Custom systems & integrations’,
    body: ‘We don’t sell platforms and we won’t make you replace anything. We build the layer on top: connecting the software you already pay for so it works as one system.’,
  },
];
---

<section id="services" class="text-cream px-5 md:px-16 py-24"
  style="background-color: #1E2A38; border-bottom: 0.5px solid rgba(140, 154, 139, 0.2);">

  <div class="max-w-[1280px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-24 items-start">

    <!-- Left: headline -->
    <div>
      <h2 class="font-serif text-[32px] md:text-[40px] text-cream leading-[1.15] font-normal">
        Most systems are built to impress on a demo. We build them to work on a Tuesday morning.
      </h2>
    </div>

    <!-- Right: service cards -->
    <div class="bg-navy-card p-10 md:p-12">
      <div class="flex flex-col gap-10">
        {services.map((service, i) => (
          <>
            <div class="flex flex-col gap-3">
              <span class="font-serif text-[48px] font-light leading-none text-accent">{service.number}</span>
              <h3 class="font-serif text-[20px] lg:text-[22px] text-cream font-medium leading-snug">
                {service.title}
              </h3>
              <p class="font-sans text-[13px] text-cream/70 leading-relaxed">
                {service.body}
              </p>
            </div>
            {i < services.length - 1 && (
              <div class="w-full h-px bg-cream/10"></div>
            )}
          </>
        ))}
      </div>
    </div>

  </div>

  <div class="max-w-[1280px] mx-auto mt-12 flex justify-end">
    <a
      href="/services"
      class="font-sans text-[13px] text-cream/60 hover:text-cream transition-colors duration-200 underline underline-offset-4"
    >
      See all services →
    </a>
  </div>

</section>
