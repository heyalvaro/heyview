---
const testimonials = [
  {
    quote: "A mí me parece que tenemos la mejor página de Costa Rica en joyería, por mucho. Demasiado bien.",
    name: "Sebastián Soto",
    company: "CoolBrand CR",
  },
];
---

<section id="testimonials" class="px-5 md:px-16 py-24" style="background-color: #E7E1D6;">

  <span class="eyebrow mb-8 block" style="color: #526251;">Testimonials</span>

  {testimonials.map((t) => (
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div>
        <blockquote class="font-serif text-[32px] md:text-[40px] text-navy leading-tight">
          {t.quote}
        </blockquote>
      </div>
      <div class="flex flex-col justify-end">
        <p class="font-sans text-[14px] font-medium" style="color: #091523;">{t.name}</p>
        <p class="font-sans text-[13px] mt-1" style="color: rgba(9, 21, 35, 0.5);">{t.company}</p>
      </div>
    </div>
  ))}

</section>
