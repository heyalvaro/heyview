---
interface Props {
  images: Array<{ src: string; caption?: string }>;
  title?: string;
}

const { images, title } = Astro.props;
---

<section class="py-20 md:py-24" style="background-color: #E7E1D6;">
  <div class="px-5 md:px-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" id="gallery-grid">
      <!-- First image spans full width -->
      {images.slice(0, 1).map((image, idx) => (
        <div
          class="md:col-span-3 aspect-video overflow-hidden group cursor-pointer"
          data-gallery-index={idx}
        >
          <img
            src={image.src}
            alt={image.caption || title || "Gallery image"}
            loading="lazy"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            data-caption={image.caption}
          />
        </div>
      ))}

      <!-- Remaining images: 1-col squares -->
      {images.slice(1).map((image, idx) => (
        <div
          class="aspect-square overflow-hidden group bg-navy cursor-pointer"
          data-gallery-index={idx + 1}
        >
          <img
            src={image.src}
            alt={image.caption || title || "Gallery image"}
            loading="lazy"
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
            data-caption={image.caption}
          />
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Lightbox Modal -->
<dialog id="gallery-lightbox" class="gallery-lightbox">
  <div class="lightbox-content">
    <button class="lightbox-close" aria-label="Close gallery">&times;</button>

    <button class="lightbox-nav lightbox-prev" aria-label="Previous image">
      <span class="material-symbols-outlined">chevron_left</span>
    </button>

    <img id="lightbox-image" src="" alt="" class="lightbox-image" />

    <button class="lightbox-nav lightbox-next" aria-label="Next image">
      <span class="material-symbols-outlined">chevron_right</span>
    </button>

    <div id="lightbox-caption" class="lightbox-caption"></div>
  </div>
</dialog>

<style>
  .gallery-lightbox {
    all: unset;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.95);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }

  .gallery-lightbox[open] {
    display: flex;
  }

  .lightbox-content {
    position: relative;
    width: 90%;
    height: 90%;
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 1200px;
  }

  .lightbox-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: rgba(0, 0, 0, 0.5);
    border: none;
    color: white;
    font-size: 40px;
    cursor: pointer;
    padding: 0;
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
    z-index: 1001;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
  }

  .lightbox-close:hover {
    background: rgba(0, 0, 0, 0.7);
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.5);
    border: none;
    color: white;
    cursor: pointer;
    padding: 12px 16px;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1001;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
  }

  .lightbox-nav:hover {
    background: rgba(0, 0, 0, 0.7);
  }

  .lightbox-prev {
    left: 20px;
  }

  .lightbox-next {
    right: 20px;
  }

  .lightbox-caption {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0, 0, 0, 0.7);
    color: white;
    padding: 12px 20px;
    border-radius: 4px;
    font-size: 14px;
    max-width: 90%;
    text-align: center;
  }

  @media (max-width: 768px) {
    .lightbox-content {
      width: 95%;
      height: 95%;
    }

    .lightbox-nav {
      padding: 8px 12px;
    }

    .lightbox-close {
      top: 10px;
      right: 10px;
      font-size: 30px;
    }
  }
</style>

<script>
  const dialog = document.getElementById('gallery-lightbox') as HTMLDialogElement | null;
  const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement | null;
  const lightboxCaption = document.getElementById('lightbox-caption') as HTMLElement | null;
  const closeBtn = document.querySelector('.lightbox-close');
  const prevBtn = document.querySelector('.lightbox-prev');
  const nextBtn = document.querySelector('.lightbox-next');
  const gallery = document.getElementById('gallery-grid');

  let currentIndex = 0;
  let images: Array<{ src: string; caption?: string }> = [];

  // Initialize gallery
  if (gallery) {
    const imgElements = gallery.querySelectorAll('img');
    images = Array.from(imgElements).map((img) => ({
      src: img.src,
      caption: img.dataset.caption || '',
    }));

    // Add click listeners to images
    imgElements.forEach((img, index) => {
      img.parentElement?.addEventListener('click', () => {
        openLightbox(index);
      });
    });
  }

  function openLightbox(index: number) {
    currentIndex = index;
    updateImage();
    dialog?.showModal();
  }

  function updateImage() {
    if (images[currentIndex] && lightboxImage && lightboxCaption) {
      lightboxImage.src = images[currentIndex].src;
      lightboxImage.alt = images[currentIndex].caption || 'Gallery image';

      if (images[currentIndex].caption) {
        lightboxCaption.textContent = images[currentIndex].caption;
        lightboxCaption.style.display = 'block';
      } else {
        lightboxCaption.style.display = 'none';
      }
    }
  }

  function closeLightbox() {
    dialog?.close();
  }

  function showNext() {
    currentIndex = (currentIndex + 1) % images.length;
    updateImage();
  }

  function showPrev() {
    currentIndex = (currentIndex - 1 + images.length) % images.length;
    updateImage();
  }

  // Event listeners
  closeBtn?.addEventListener('click', closeLightbox);
  nextBtn?.addEventListener('click', showNext);
  prevBtn?.addEventListener('click', showPrev);

  // Close on backdrop click
  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) {
      closeLightbox();
    }
  });

  // Keyboard controls
  document.addEventListener('keydown', (e) => {
    if (dialog && dialog.open) {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') showNext();
      if (e.key === 'ArrowLeft') showPrev();
    }
  });
</script>
