---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { CAL_LINK, CAL_NAMESPACE, CAL_CONFIG } from '../config';

const painPoints = [
  'A no-show isn\'t an inconvenience. It\'s inventory that expired.',
  'Patients book with whoever answers first — including at 9 PM.',
  'Your team\'s hours go to chasing, not caring.',
];

const systemPillars = [
  {
    title: 'Booking that never sleeps',
    body: 'Conversational booking on WhatsApp and SMS, in your tone. It answers instantly, finds the right slot with the right practitioner, and pre-fills intake from prior visits — so the patient shows up with the paperwork already done.',
  },
  {
    title: 'No-show recovery',
    body: 'The system flags the appointments most likely to fail and starts the conversation before they do: confirmation 24 hours out, again 4 hours out, instant rebooking when someone cancels, and win-back messages for patients who quietly disappeared.',
  },
  {
    title: 'A dashboard your front desk opens every morning',
    body: 'Today\'s schedule, who\'s confirmed, who\'s at risk, what to do next. The owner gets the weekly view: occupancy, recovered revenue, where patients come from. One screen, one version of the truth.',
  },
];

const stages = [
  {
    number: '01',
    title: 'Discovery',
    body: 'We map how patients actually move through your practice — from first message to follow-up — before touching anything.',
  },
  {
    number: '02',
    title: 'Strategy',
    body: "You get a written plan: what we'll build, what it replaces, and a fixed quote. You know the full cost before we build a line of code.",
  },
  {
    number: '03',
    title: 'Execution',
    body: 'We build it. You see progress every week, on the real system, not in slides.',
  },
  {
    number: '04',
    title: 'Handoff',
    body: "You own everything: documented, transferred, explained. If we did our job, you don't need us afterward. Most clients keep us anyway, to evolve the system.",
  },
];

const fits = {
  good: [
    '2–8 practitioners. Already using online booking or modern practice software.',
    'Growing — new chairs, new rooms, maybe a second location — and the admin didn\'t scale with you.',
  ],
  notFit: [
    'Solo practice with no admin staff.',
    'PE-owned chains with procurement committees.',
    'Anyone shopping for the cheapest option.',
  ],
};

const specialties = [
  'Dental clinics',
  'Aesthetic and dermatology practices',
  'Orthopedics',
  'Physical therapy',
  'Ophthalmology',
  'Veterinary',
];
---

<Layout
  title="Operations & AI systems for specialty practices — HeyView"
  description="Stop losing revenue to no-shows and manual admin. Booking that answers at 9 PM, follow-up that doesn't forget, and a dashboard your front desk actually uses."
>
  <div class="max-w-360 mx-auto relative shadow-sm">
    <Navbar transition:persist />
    <main>

      <!-- 1. Hero -->
      <section class="grain bg-cream px-5 md:px-16 py-24 md:py-32" style="border-bottom: 0.5px solid #E7E1D6;">
        <div class="max-w-[1280px] mx-auto">
          <span class="eyebrow text-navy/60 block mb-8">For specialty practices</span>
          <h1 class="font-serif text-[40px] md:text-[64px] text-navy font-light leading-[1.1] max-w-3xl mb-8">
            Stop losing revenue to no-shows and manual admin.
          </h1>
          <p class="font-sans text-[17px] md:text-[20px] text-secondary leading-relaxed max-w-2xl mb-12">
            Your schedule is your inventory. Every empty chair is a sale you can't make twice — and most of them were preventable. We build the operations system that fills them: booking that answers at 9 PM, follow-up that doesn't forget, and a dashboard your front desk actually uses.
          </p>
          <button
            data-cal-link={CAL_LINK}
            data-cal-namespace={CAL_NAMESPACE}
            data-cal-config={CAL_CONFIG}
            class="bg-navy text-cream px-8 py-4 font-sans text-[13px] font-medium tracking-wide hover:opacity-90 transition-opacity uppercase cursor-pointer"
          >
            Book a discovery call
          </button>
        </div>
      </section>

      <!-- 2. The pain -->
      <section class="px-5 md:px-16 py-20 md:py-24 bg-[#F9F5EE]" style="border-bottom: 0.5px solid #E7E1D6;">
        <div class="max-w-[1280px] mx-auto">
          <h2 class="font-serif text-[28px] md:text-[36px] text-navy font-normal leading-[1.2] mb-6 max-w-2xl">
            You didn't open a practice to chase confirmations.
          </h2>
          <p class="font-sans text-[15px] md:text-[17px] text-secondary leading-relaxed max-w-2xl mb-12">
            A patient books, then goes quiet. The front desk calls twice, leaves a voicemail, moves on — there are forty other things to do. The slot stays empty, the overhead doesn't. Multiply that by every week, add the intake forms typed twice and the "can I reschedule?" messages arriving at night on WhatsApp, and you get the real number: most practices lose more revenue to admin friction than to competition.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {painPoints.map((point) => (
              <div class="flex gap-4 items-start">
                <span class="flex-shrink-0 w-1.5 h-1.5 rounded-full bg-accent mt-2"></span>
                <p class="font-sans text-[15px] text-secondary leading-relaxed">{point}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- 3. The system -->
      <section class="px-5 md:px-16 py-20 md:py-24 bg-cream" style="border-bottom: 0.5px solid #E7E1D6;">
        <div class="max-w-[1280px] mx-auto">
          <h2 class="font-serif text-[28px] md:text-[36px] text-navy font-normal leading-[1.2] mb-4">
            One system for the whole patient journey.
          </h2>
          <p class="font-sans text-[15px] md:text-[17px] text-secondary leading-relaxed max-w-2xl mb-16">
            Built on top of the scheduling software and tools you already use — nothing gets replaced, your team doesn't relearn anything.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-1 gap-12 md:gap-16">
            {systemPillars.map((pillar, i) => (
              <div class="flex flex-col gap-3">
                <h3 class="font-serif text-[22px] text-navy font-medium leading-snug">
                  {pillar.title}
                </h3>
                <p class="font-sans text-[15px] text-secondary leading-relaxed max-w-2xl">
                  {pillar.body}
                </p>
              </div>
            ))}
          </div>

          <div class="mt-16 pt-12" style="border-top: 0.5px solid #E7E1D6;">
            <p class="font-sans text-[15px] text-secondary leading-relaxed max-w-2xl">
              <span class="font-medium">Add-ons when you need them:</span> review automation, multi-location support, AI phone reception, custom integrations.
            </p>
          </div>
        </div>
      </section>

      <!-- 4. Why us (pedigree) -->
      <section class="px-5 md:px-16 py-20 md:py-24 bg-[#F9F5EE]" style="border-bottom: 0.5px solid #E7E1D6;">
        <div class="max-w-[1280px] mx-auto">
          <h2 class="font-serif text-[28px] md:text-[36px] text-navy font-normal leading-[1.2] mb-6 max-w-2xl">
            We've been building for healthcare since before AI was a pitch.
          </h2>
          <p class="font-sans text-[15px] md:text-[17px] text-secondary leading-relaxed max-w-2xl mb-8">
            Nine years building systems for hospitals and healthcare brands. Twenty-two years architecting operations for multinationals — including a capacity-planning system for a global medical device manufacturer and a finance close that went from 80 hours a month to six. We're not a chatbot reseller discovering medicine this quarter. We know why your scheduling software, your records, and your front desk don't talk to each other — and how to fix it without replacing any of them.
          </p>
          <a
            href="/work"
            class="font-sans text-[13px] text-navy/60 hover:text-navy transition-colors duration-200 underline underline-offset-4"
          >
            See the work →
          </a>
        </div>
      </section>

      <!-- 5. Who this is for -->
      <section class="px-5 md:px-16 py-20 md:py-24 bg-cream" style="border-bottom: 0.5px solid #E7E1D6;">
        <div class="max-w-[1280px] mx-auto">
          <h2 class="font-serif text-[28px] md:text-[36px] text-navy font-normal leading-[1.2] mb-8">
            Built for practices that run on appointments.
          </h2>

          <p class="font-sans text-[15px] md:text-[17px] text-secondary leading-relaxed max-w-2xl mb-12">
            <span class="font-medium">Dental clinics, aesthetic and dermatology practices, orthopedics, physical therapy, ophthalmology, veterinary.</span> If your week lives or dies by the schedule — and you have a team running it — this is for you.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-0 mb-16" style="border: 0.5px solid #E7E1D6;">
            <div class="p-10 md:p-12" style="border-right: 0.5px solid #E7E1D6; border-bottom: 0.5px solid #E7E1D6;">
              <h3 class="font-serif text-[20px] text-navy font-medium mb-6">A good fit</h3>
              <ul class="space-y-4">
                {fits.good.map((item) => (
                  <li class="flex gap-3 items-start">
                    <span class="font-serif text-accent text-[18px] leading-none mt-0.5 flex-shrink-0">—</span>
                    <span class="font-sans text-[14px] text-secondary leading-relaxed">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="p-10 md:p-12 bg-[#F9F5EE]" style="border-bottom: 0.5px solid #E7E1D6;">
              <h3 class="font-serif text-[20px] text-navy font-medium mb-6">Not a fit</h3>
              <ul class="space-y-4">
                {fits.notFit.map((item) => (
                  <li class="flex gap-3 items-start">
                    <span class="font-serif text-navy/30 text-[18px] leading-none mt-0.5 flex-shrink-0">—</span>
                    <span class="font-sans text-[14px] text-secondary/70 leading-relaxed">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- 6. How it works -->
      <section class="grain bg-cream px-5 md:px-16 py-20 md:py-28" style="border-bottom: 0.5px solid #E7E1D6;">
        <div class="max-w-[1280px] mx-auto">
          <span class="eyebrow text-navy/60 block mb-6">How we work</span>
          <h2 class="font-serif text-[28px] md:text-[36px] text-navy font-normal mb-4 leading-[1.2]">
            Four stages. No surprises.
          </h2>
          <p class="font-sans text-[15px] text-secondary leading-relaxed max-w-2xl mb-16">
            Fixed scope, fixed quote, senior founders doing the work. No hourly billing. You'll know the full cost before we build.
          </p>

          <div class="relative">
            <div class="absolute bg-cream-border left-[5px] top-0 bottom-0 w-px md:left-0 md:top-[5px] md:bottom-auto md:w-full md:h-px"></div>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8 relative z-10">
              {stages.map((stage) => (
                <div class="flex flex-row md:flex-col gap-6 md:gap-0">
                  <div class="flex-shrink-0 w-3 md:w-full h-auto md:h-3 flex items-start md:items-center justify-center md:justify-start">
                    <div class="w-[11px] h-[11px] rounded-full bg-accent ring-2 ring-cream mt-0.5 md:mt-0"></div>
                  </div>
                  <div class="pt-0 md:pt-10 flex-1">
                    <span class="font-serif text-[52px] text-accent leading-none font-normal block mb-3 select-none">
                      {stage.number}
                    </span>
                    <h3 class="font-serif text-[22px] text-navy font-normal mb-2">{stage.title}</h3>
                    <p class="font-sans text-[13px] text-navy/70 leading-relaxed">{stage.body}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- 7. CTA -->
      <section class="px-5 md:px-16 py-24 md:py-32 bg-[#F9F5EE]" style="border-bottom: 0.5px solid #E7E1D6;">
        <div class="max-w-[1280px] mx-auto">
          <h2 class="font-serif text-[32px] md:text-[48px] text-navy font-normal leading-[1.15] mb-6 max-w-2xl">
            Thirty minutes on your practice. Not a sales call.
          </h2>
          <p class="font-sans text-[15px] md:text-[17px] text-secondary leading-relaxed max-w-2xl mb-8">
            Tell us how booking works today, where the no-shows hurt, what the front desk dreads. We'll tell you what we'd automate first — and what we wouldn't touch. You leave with a clearer picture of your own operation, whether or not we ever work together.
          </p>
          <div class="flex flex-col items-start gap-4">
            <button
              data-cal-link={CAL_LINK}
              data-cal-namespace={CAL_NAMESPACE}
              data-cal-config={CAL_CONFIG}
              class="bg-navy text-cream px-8 py-4 font-sans text-[13px] font-medium tracking-wide hover:opacity-90 transition-opacity uppercase cursor-pointer"
            >
              Book a discovery call
            </button>
            <span class="font-sans text-[12px] text-navy/40">
              English or Spanish. No prep needed.
            </span>
          </div>
        </div>
      </section>

    </main>
    <Footer />
  </div>
</Layout>
