    .svc-page .stat-value { font-size: 64px; }
    .svc-page .process-steps { grid-template-columns: 1fr; gap: 0; }
    .svc-page .process-line { top: 0; bottom: 0; left: 5px; right: auto; width: 1px; height: auto; }
    .svc-page .process-step { padding: 0 0 32px 32px; }
