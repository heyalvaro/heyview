---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Services — HeyView"
  description="HeyView builds AI automation, operations dashboards, and system integrations for specialty practices and operations teams. Fixed scope, senior hands, four-week delivery."
>
  <div class="max-w-360 mx-auto relative shadow-sm">
    <Navbar transition:persist />
    <main id="main-content">
      <div class="svc-page">

      <!-- 1. HERO -->
      <section id="hero" aria-label="Services overview">
        <div class="svc-container">
          <div class="hero-grid">
            <div class="hero-main">
              <span class="svc-eyebrow">Services</span>
              <h1 class="hero-h1">Systems that work on a Tuesday morning.</h1>
              <p class="hero-body">Most systems are built to impress on a demo. We build the kind that still runs when the founder is on vacation, the new hire started Monday, and it's just another Tuesday. Automation, internal tools, and AI — built on top of the software you already use.</p>
              <a href="https://cal.com/heyview/discovery" class="svc-btn svc-btn-primary" aria-label="Book a discovery call" target="_blank" rel="noopener noreferrer">Book a discovery call</a>
            </div>
            <nav class="hero-index" aria-label="Services navigation">
              <span class="hero-index-label">Four capabilities</span>
              <ul>
                <li><a href="#automation" aria-label="Jump to Automation"><span class="hi-num">01</span><span class="hi-name">Automation</span><span class="hi-arrow" aria-hidden="true">→</span></a></li>
                <li><a href="#assistants" aria-label="Jump to AI Assistants"><span class="hi-num">02</span><span class="hi-name">AI Assistants</span><span class="hi-arrow" aria-hidden="true">→</span></a></li>
                <li><a href="#dashboards" aria-label="Jump to Dashboards"><span class="hi-num">03</span><span class="hi-name">Dashboards</span><span class="hi-arrow" aria-hidden="true">→</span></a></li>
                <li><a href="#integrations" aria-label="Jump to Integrations"><span class="hi-num">04</span><span class="hi-name">Integrations</span><span class="hi-arrow" aria-hidden="true">→</span></a></li>
              </ul>
            </nav>
          </div>
        </div>
      </section>

      <!-- SERVICE 01 — AUTOMATION (dark) -->
      <section class="service service--dark" id="automation" aria-label="Service: Document and process automation">
        <div class="svc-container">
          <div class="service-head">
            <span class="service-num">01</span>
            <span class="service-kicker"><span class="service-tag">Document automation</span></span>
          </div>
          <div class="service-grid">
            <div class="service-text">
              <h2 class="service-h2">Your business runs on a process that shouldn't exist.</h2>
              <p class="service-body">If a document takes three people and two days to produce every week, that's not a process. That's a problem with a routine. We automate the routine: generating documents, routing approvals, moving data between systems, filling the same signature for the fourth time.</p>
            </div>
            <div class="service-viz" aria-hidden="true">
              <svg viewBox="0 0 400 260" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="24" y="40" width="120" height="150" rx="8" stroke="#8C9ABB" stroke-width="1.5" stroke-opacity="0.55"/>
                <rect x="44" y="64" width="80" height="7" rx="3" fill="#8C9ABB" fill-opacity="0.5"/>
                <rect x="44" y="82" width="64" height="7" rx="3" fill="#8C9ABB" fill-opacity="0.35"/>
                <rect x="44" y="100" width="80" height="7" rx="3" fill="#8C9ABB" fill-opacity="0.35"/>
                <rect x="44" y="118" width="52" height="7" rx="3" fill="#8C9ABB" fill-opacity="0.35"/>
                <rect x="44" y="150" width="44" height="14" rx="7" fill="#A67C52" fill-opacity="0.25" stroke="#A67C52" stroke-width="1" stroke-opacity="0.5"/>
                <line x1="152" y1="115" x2="196" y2="115" stroke="#A67C52" stroke-width="1.5" stroke-opacity="0.6" stroke-dasharray="4 3"/>
                <circle cx="222" cy="115" r="26" stroke="#A67C52" stroke-width="1.5" stroke-opacity="0.6"/>
                <path d="M212 115l7 7 12-14" stroke="#A67C52" stroke-width="1.8" stroke-opacity="0.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                <line x1="248" y1="115" x2="292" y2="115" stroke="#8C9ABB" stroke-width="1.5" stroke-opacity="0.4" stroke-dasharray="4 3"/>
                <rect x="300" y="60" width="76" height="50" rx="6" fill="#8C9ABB" fill-opacity="0.08" stroke="#8C9ABB" stroke-width="1" stroke-opacity="0.4"/>
                <rect x="314" y="78" width="48" height="6" rx="3" fill="#8C9ABB" fill-opacity="0.45"/>
                <rect x="314" y="90" width="32" height="6" rx="3" fill="#8C9ABB" fill-opacity="0.3"/>
                <rect x="300" y="120" width="76" height="50" rx="6" fill="#8C9ABB" fill-opacity="0.08" stroke="#8C9ABB" stroke-width="1" stroke-opacity="0.4"/>
                <rect x="314" y="138" width="48" height="6" rx="3" fill="#8C9ABB" fill-opacity="0.45"/>
                <rect x="314" y="150" width="40" height="6" rx="3" fill="#8C9ABB" fill-opacity="0.3"/>
              </svg>
            </div>
          </div>
          <div class="service-get">
            <span class="get-label">What you get</span>
            <ul class="get-list" aria-label="What you get">
              <li>
                <span class="get-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12.5l5 5L20 6.5"/></svg></span>
                <span class="get-text">Fewer errors every week. Time that doesn't depend on who's in the office.</span>
              </li>
              <li>
                <span class="get-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12.5l5 5L20 6.5"/></svg></span>
                <span class="get-text">An automated workflow for any document your business generates — no manual entry, no version confusion, and a clear audit trail.</span>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- SERVICE 02 — AI ASSISTANTS (light, flipped) -->
      <section class="service service--flip" id="assistants" aria-label="Service: Customer communication and AI assistants">
        <div class="svc-container">
          <div class="service-head">
            <span class="service-num">02</span>
            <span class="service-kicker"><span class="service-tag">Customer communication &amp; AI assistants</span></span>
          </div>
          <div class="service-grid">
            <div class="service-text">
              <h2 class="service-h2">Every unanswered message is revenue walking out the door.</h2>
              <p class="service-body">Your customers write at 9PM on WhatsApp, Instagram, and email — and they buy from whoever answers first. We build AI assistants that respond instantly, book from wherever answers, follow up, and win back the ones who went quiet. With a human taking over the moment it matters.</p>
            </div>
            <div class="service-viz" aria-hidden="true">
              <svg viewBox="0 0 400 260" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="60" y="20" width="280" height="220" rx="16" stroke="#8C9ABB" stroke-width="1.5" stroke-opacity="0.5"/>
                <rect x="60" y="20" width="280" height="44" rx="16" fill="#8C9ABB" fill-opacity="0.08"/>
                <circle cx="86" cy="42" r="9" fill="#A67C52" fill-opacity="0.6"/>
                <rect x="104" y="38" width="90" height="8" rx="4" fill="#8C9ABB" fill-opacity="0.5"/>
                <rect x="84" y="86" width="150" height="36" rx="18" fill="#8C9ABB" fill-opacity="0.12" stroke="#8C9ABB" stroke-width="1" stroke-opacity="0.35"/>
                <rect x="100" y="100" width="110" height="8" rx="4" fill="#8C9ABB" fill-opacity="0.5"/>
                <rect x="166" y="134" width="150" height="48" rx="18" fill="#A67C52" fill-opacity="0.16" stroke="#A67C52" stroke-width="1" stroke-opacity="0.5"/>
                <rect x="182" y="148" width="118" height="8" rx="4" fill="#A67C52" fill-opacity="0.6"/>
                <rect x="182" y="162" width="80" height="8" rx="4" fill="#A67C52" fill-opacity="0.4"/>
                <rect x="84" y="196" width="120" height="30" rx="15" fill="#8C9ABB" fill-opacity="0.12" stroke="#8C9ABB" stroke-width="1" stroke-opacity="0.35"/>
                <rect x="100" y="208" width="80" height="7" rx="3" fill="#8C9ABB" fill-opacity="0.45"/>
              </svg>
            </div>
          </div>
          <div class="service-get">
            <span class="get-label">What you get</span>
            <ul class="get-list" aria-label="What you get">
              <li>
                <span class="get-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12.5l5 5L20 6.5"/></svg></span>
                <span class="get-text">Faster response than any front desk. Never missed leads and no-shows. Recovered revenue you can actually count.</span>
              </li>
              <li>
                <span class="get-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12.5l5 5L20 6.5"/></svg></span>
                <span class="get-text">AI appointment assistant — confirmed and reminded. AI inbox for WhatsApp, Instagram, and email — qualified and routed.</span>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- SERVICE 03 — DASHBOARDS (dark) -->
      <section class="service service--dark" id="dashboards" aria-label="Service: Operations dashboards">
        <div class="svc-container">
          <div class="service-head">
            <span class="service-num">03</span>
            <span class="service-kicker"><span class="service-tag">Operations dashboards</span></span>
          </div>
          <div class="service-grid">
            <div class="service-text">
              <h2 class="service-h2">Stop running the business from a spreadsheet only one person understands.</h2>
              <p class="service-body">Reports tell you what happened. We build dashboards that tell you what to do next — designed for the person making the decision, not the person making the report. One version of the truth.</p>
            </div>
            <div class="service-viz" aria-hidden="true">
              <svg viewBox="0 0 400 260" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="20" y="20" width="360" height="220" rx="8" stroke="#8C9ABB" stroke-width="1.5" stroke-opacity="0.45"/>
                <rect x="40" y="40" width="96" height="58" rx="6" fill="#A67C52" fill-opacity="0.1" stroke="#A67C52" stroke-width="1" stroke-opacity="0.35"/>
                <rect x="52" y="52" width="40" height="16" rx="3" fill="#A67C52" fill-opacity="0.45"/>
                <rect x="52" y="76" width="56" height="6" rx="3" fill="#A67C52" fill-opacity="0.3"/>
                <rect x="152" y="40" width="96" height="58" rx="6" fill="#8C9ABB" fill-opacity="0.08" stroke="#8C9ABB" stroke-width="1" stroke-opacity="0.3"/>
                <rect x="164" y="52" width="40" height="16" rx="3" fill="#8C9ABB" fill-opacity="0.45"/>
                <rect x="164" y="76" width="48" height="6" rx="3" fill="#8C9ABB" fill-opacity="0.3"/>
                <rect x="264" y="40" width="96" height="58" rx="6" fill="#8C9ABB" fill-opacity="0.08" stroke="#8C9ABB" stroke-width="1" stroke-opacity="0.3"/>
                <rect x="276" y="52" width="40" height="16" rx="3" fill="#8C9ABB" fill-opacity="0.45"/>
                <rect x="276" y="76" width="52" height="6" rx="3" fill="#8C9ABB" fill-opacity="0.3"/>
                <rect x="40" y="116" width="320" height="104" rx="6" fill="#8C9ABB" fill-opacity="0.05" stroke="#8C9ABB" stroke-width="1" stroke-opacity="0.25"/>
                <polyline points="60,196 100,176 140,184 180,156 220,164 260,140 300,148 340,124" stroke="#A67C52" stroke-width="2" stroke-opacity="0.65" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="60,206 100,198 140,202 180,188 220,192 260,178 300,182 340,170" stroke="#8C9ABB" stroke-width="1.5" stroke-opacity="0.45" fill="none" stroke-dasharray="4 3"/>
              </svg>
            </div>
          </div>
          <div class="service-get">
            <span class="get-label">What you get</span>
            <ul class="get-list" aria-label="What you get">
              <li>
                <span class="get-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12.5l5 5L20 6.5"/></svg></span>
                <span class="get-text">A screen your team actually opens every morning. Numbers you can defend.</span>
              </li>
              <li>
                <span class="get-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12.5l5 5L20 6.5"/></svg></span>
                <span class="get-text">We design reports around the decisions you make. We build the infrastructure that keeps the data clean — searchable, consistent, defensible.</span>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- SERVICE 04 — INTEGRATIONS (light, flipped) -->
      <section class="service service--flip" id="integrations" aria-label="Service: Integrations">
        <div class="svc-container">
          <div class="service-head">
            <span class="service-num">04</span>
            <span class="service-kicker"><span class="service-tag">Integrations</span></span>
          </div>
          <div class="service-grid">
            <div class="service-text">
              <h2 class="service-h2">You already pay for good software. It just doesn't talk to itself.</h2>
              <p class="service-body">We don't sell platforms and we won't make you replace anything. We spend the first week connecting your scheduling tool to your billing, your CRM to your spreadsheets, your forms to the system that actually needs the data. And when the problem is unusual — searchable company knowledge, AI over years of documents — this is where we build that too.</p>
            </div>
            <div class="service-viz" aria-hidden="true">
              <svg viewBox="0 0 400 260" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line x1="200" y1="130" x2="70" y2="56" stroke="#8C9ABB" stroke-width="1.2" stroke-opacity="0.35" stroke-dasharray="4 3"/>
                <line x1="200" y1="130" x2="330" y2="56" stroke="#8C9ABB" stroke-width="1.2" stroke-opacity="0.35" stroke-dasharray="4 3"/>
                <line x1="200" y1="130" x2="60" y2="200" stroke="#8C9ABB" stroke-width="1.2" stroke-opacity="0.35" stroke-dasharray="4 3"/>
                <line x1="200" y1="130" x2="340" y2="200" stroke="#8C9ABB" stroke-width="1.2" stroke-opacity="0.35" stroke-dasharray="4 3"/>
                <circle cx="200" cy="130" r="34" fill="#A67C52" fill-opacity="0.12" stroke="#A67C52" stroke-width="1.5" stroke-opacity="0.6"/>
                <circle cx="200" cy="130" r="6" fill="#A67C52" fill-opacity="0.7"/>
                <rect x="34" y="36" width="72" height="40" rx="8" fill="#8C9ABB" fill-opacity="0.1" stroke="#8C9ABB" stroke-width="1" stroke-opacity="0.4"/>
                <rect x="48" y="52" width="44" height="8" rx="4" fill="#8C9ABB" fill-opacity="0.5"/>
                <rect x="294" y="36" width="72" height="40" rx="8" fill="#8C9ABB" fill-opacity="0.1" stroke="#8C9ABB" stroke-width="1" stroke-opacity="0.4"/>
                <rect x="308" y="52" width="44" height="8" rx="4" fill="#8C9ABB" fill-opacity="0.5"/>
                <rect x="24" y="180" width="72" height="40" rx="8" fill="#8C9ABB" fill-opacity="0.1" stroke="#8C9ABB" stroke-width="1" stroke-opacity="0.4"/>
                <rect x="38" y="196" width="44" height="8" rx="4" fill="#8C9ABB" fill-opacity="0.5"/>
                <rect x="304" y="180" width="72" height="40" rx="8" fill="#8C9ABB" fill-opacity="0.1" stroke="#8C9ABB" stroke-width="1" stroke-opacity="0.4"/>
                <rect x="318" y="196" width="44" height="8" rx="4" fill="#8C9ABB" fill-opacity="0.5"/>
              </svg>
            </div>
          </div>
          <div class="service-get">
            <span class="get-label">What you get</span>
            <ul class="get-list" aria-label="What you get">
              <li>
                <span class="get-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12.5l5 5L20 6.5"/></svg></span>
                <span class="get-text">The stack you already have, working as one system.</span>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- DESIGNED, NOT JUST BUILT (dark) -->
      <section id="studio" aria-label="About our approach">
        <div class="svc-container">
          <div class="studio-grid">
            <div>
              <span class="svc-eyebrow on-dark">The studio</span>
              <h2 class="studio-h2">Designed, not just built.</h2>
              <p class="studio-body">Half of this studio is a senior product designer. Every dashboard, internal tool, and AI we ship meets the same design standard as a public, loved brand site — because software people don't hate using is software people actually use. That's not polish on top. It's why the systems stick.</p>
              <a class="studio-link" href="/work" aria-label="View our work">Our work <span aria-hidden="true">→</span></a>
            </div>
            <div class="stat-card" aria-label="22 years building systems for hospitals, multinationals, and enterprise operations">
              <span class="stat-kicker">Track record</span>
              <div class="stat-value">22<span class="stat-plus" aria-hidden="true">+</span></div>
              <div class="stat-unit">years building systems</div>
              <ul class="stat-domains" aria-label="Where we've built">
                <li>Hospitals &amp; healthcare</li>
                <li>Global multinationals</li>
                <li>Enterprise operations</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- PROCESS -->
      <section id="process" aria-label="Our process">
        <div class="svc-container">
          <span class="svc-eyebrow">How we work</span>
          <h2 class="process-h2">Four stages. No surprises.</h2>
          <div class="process-wrap">
            <div class="process-line" aria-hidden="true"></div>
            <ol class="process-steps" aria-label="Four-step process">
              <li class="process-step">
                <span class="process-dot" aria-hidden="true"></span>
                <div class="process-num">01</div>
                <h3 class="process-title">Discovery</h3>
                <p class="process-body">We map how the work actually happens, not how the org chart says it happens. Expect uncomfortable questions.</p>
              </li>
              <li class="process-step">
                <span class="process-dot" aria-hidden="true"></span>
                <div class="process-num">02</div>
                <h3 class="process-title">Strategy</h3>
                <p class="process-body">You get a written plan: what we'll build, what it replaces, and a fixed quote. You know the full cost before we write a line of code.</p>
              </li>
              <li class="process-step">
                <span class="process-dot" aria-hidden="true"></span>
                <div class="process-num">03</div>
                <h3 class="process-title">Execution</h3>
                <p class="process-body">We build it. You see progress every week, on the real system, not in slides.</p>
              </li>
              <li class="process-step">
                <span class="process-dot" aria-hidden="true"></span>
                <div class="process-num">04</div>
                <h3 class="process-title">Handoff</h3>
                <p class="process-body">You own everything: documented, transferred, explained. If we did our job, you don't need us afterward.</p>
              </li>
            </ol>
          </div>
          <div class="process-cta">
            <a href="https://cal.com/heyview/discovery" class="svc-btn svc-btn-primary" aria-label="Book a discovery call" target="_blank" rel="noopener noreferrer">Book a discovery call</a>
          </div>
        </div>
      </section>

      <!-- PRICING (stone) -->
      <section id="pricing" aria-label="Pricing model">
        <div class="svc-container">
          <div class="pricing-grid">
            <div>
              <span class="svc-eyebrow">The model</span>
              <h2 class="pricing-h2">Fixed scope.<br>Fixed quote.<br>Senior hands.</h2>
            </div>
            <div class="pricing-blocks">
              <div class="pricing-card">
                <span class="pricing-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="3"/><path d="M6 12h.01M18 12h.01"/></svg>
                </span>
                <div>
                  <div class="pricing-label">No hourly billing</div>
                  <p class="pricing-body">No hourly billing, ever — you buy an outcome, not our time. Scope changes get a new quote. In writing, before anything moves.</p>
                </div>
              </div>
              <div class="pricing-card">
                <span class="pricing-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </span>
                <div>
                  <div class="pricing-label">Small team, no layers</div>
                  <p class="pricing-body">We take two to three new clients per quarter, and the founders do the work: no account managers, no junior team learning on your project.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- FIT / NO FIT -->
      <section id="fit" aria-label="Is this a good fit?">
        <div class="svc-container">
          <span class="svc-eyebrow">The match</span>
          <h2 class="fit-h2">A good fit, honestly.</h2>
          <div class="fit-grid">
            <div class="fit-card fit-card-light" role="region" aria-label="This is for you if">
              <div class="fit-card-label">This is for you if</div>
              <ul class="fit-list">
                <li><span class="fit-mark" aria-hidden="true">✓</span> Your business runs on real operations — appointments, documents, approvals, inventory, billing.</li>
                <li><span class="fit-mark" aria-hidden="true">✓</span> You're drowning in non-revenue software.</li>
                <li><span class="fit-mark" aria-hidden="true">✓</span> Something grew quickly and the processes didn't keep up.</li>
                <li><span class="fit-mark" aria-hidden="true">✓</span> You can make this decision without a committee.</li>
              </ul>
            </div>
            <div class="fit-card fit-card-dark" role="region" aria-label="This isn't for you if">
              <div class="fit-card-label">This isn't for you if</div>
              <ul class="fit-list">
                <li><span class="fit-mark" aria-hidden="true">×</span> You're looking for the cheapest option.</li>
                <li><span class="fit-mark" aria-hidden="true">×</span> You want a pile of presentations instead of a working system.</li>
                <li><span class="fit-mark" aria-hidden="true">×</span> Your procurement process is longer than our delivery.</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- BY INDUSTRY (stone) -->
      <section id="vertical" aria-label="Industries we serve">
        <div class="svc-container">
          <div class="vertical-grid">
            <div>
              <span class="svc-eyebrow">By industry</span>
              <h2 class="vertical-h2">Where this lands hardest.</h2>
              <p class="vertical-body">The systems are the same. The pain is specific. We go deep where we know the industry from the inside.</p>
            </div>
