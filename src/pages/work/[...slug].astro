---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import JnjStory from '../../components/work/JnjStory.astro';

// Flagship projects can override the generic prose body with a bespoke,
// fully-designed story component, keyed by slug.
const customStories: Record<string, any> = {
  'jnj-capacity-model': JnjStory,
};

// Generate a page for every non-draft, non-confidential project.
export const getStaticPaths = (async () => {
  const projects = await getCollection(
    'work',
    ({ data }) => !data.draft && !data.confidential,
  );
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const { Content } = await render(project);
const CustomStory = customStories[project.id];
const { title, summary, tag, cover, client, year, industry, period, stats, gallery } = project.data;

const pageUrl = new URL(`/work/${project.id}`, Astro.site).href;
const metaRow = [industry, client, period].filter(Boolean).join(' · ');

// Sibling projects for prev/next navigation (sorted by order, then title).
const allProjects = (await getCollection('work', ({ data }) => !data.draft && !data.confidential))
  .sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100));
const currentIdx = allProjects.findIndex((p) => p.id === project.id);
const prevProject = currentIdx > 0 ? allProjects[currentIdx - 1] : null;
const nextProject = currentIdx < allProjects.length - 1 ? allProjects[currentIdx + 1] : null;

// CreativeWork schema — clean, machine-readable facts for rich results + AI.
const schema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: title,
  abstract: summary,
  url: pageUrl,
  ...(cover && { image: new URL(cover, Astro.site).href }),
  about: tag,
  creator: { '@type': 'Organization', name: 'HeyView Studio' },
  ...(client && { sourceOrganization: { '@type': 'Organization', name: client } }),
  ...(year && { datePublished: String(year) }),
};
---

<Layout title={`${title} — HeyView`} description={summary} image={cover} type="article">
  <div class="max-w-360 mx-auto relative shadow-sm">
    <Navbar />
    <main id="main-content">
      <article class="bg-navy">

        <!-- ── Hero ──────────────────────────────────────────────────────── -->
        <div class="grain px-5 md:px-16 pt-24 pb-16">
          <a
            href="/work"
            class="font-sans text-[13px] transition-colors"
            style="color: rgba(245,240,232,0.45);"
            onmouseover="this.style.color='rgba(245,240,232,0.8)'"
            onmouseout="this.style.color='rgba(245,240,232,0.45)'"
          >← All work</a>

          <span class="eyebrow text-accent-green block mt-10 mb-5">{tag}</span>

          <h1 class="font-serif text-[44px] md:text-[64px] text-cream font-light leading-[1.1] max-w-4xl">
            {title}
          </h1>

          <p
            class="font-sans text-[17px] md:text-[20px] leading-relaxed max-w-2xl mt-6"
            style="color: rgba(245,240,232,0.65);"
          >
            {summary}
          </p>

          {metaRow && (
            <p class="font-sans text-[13px] mt-8" style="color: rgba(245,240,232,0.4);">
              {metaRow}
            </p>
          )}
        </div>

        <!-- ── Cover image ───────────────────────────────────────────────── -->
        {cover ? (
          <div
            role="img"
            aria-label={title}
            class="h-80 md:h-128 w-full bg-cover bg-center"
            style={`background-image: url('${cover}');`}
          />
        ) : (
          <div
            class="h-56 md:h-80 w-full flex items-center justify-center"
            style="background-image: linear-gradient(135deg, #2a3848 0%, #1a242f 100%);"
          >
            <span class="material-symbols-outlined" style="font-size:88px; color: rgba(245,240,232,0.15);">monitoring</span>
          </div>
        )}

        <!-- ── Stats band ─────────────────────────────────────────────────── -->
        {stats && stats.length > 0 && (
          <div class="bg-cream px-5 md:px-16 py-14" style="border-bottom: 0.5px solid #E7E1D6;">
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-x-0 gap-y-10">
              {stats.map((stat, i) => (
                <div
                  class="pr-8"
                  style={i > 0 ? 'border-left: 0.5px solid #E7E1D6; padding-left: 2rem;' : ''}
                >
                  <div class="font-serif text-[44px] md:text-[52px] text-accent font-light leading-none">
                    {stat.value}
                  </div>
                  <div class="eyebrow text-accent-green mt-3">{stat.label}</div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- ── Body ──────────────────────────────────────────────────────── -->
        {CustomStory ? (
          <CustomStory />
        ) : (
          <div class="bg-cream px-5 md:px-16 py-16 md:py-24">
            <div class="prose-light font-sans text-[17px] leading-relaxed max-w-2xl">
              <Content />
            </div>
          </div>
        )}

        <!-- ── Gallery ───────────────────────────────────────────────────── -->
        {gallery && gallery.length > 0 && (
          <div class="bg-cream px-5 md:px-16 pb-20" style="border-top: 0.5px solid #E7E1D6;">
            <div class="pt-14 pb-2">
              <span class="eyebrow text-accent-green">From the project</span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
              {gallery.map((shot) => (
                <figure class="flex flex-col">
                  <img
                    src={shot.src}
                    alt={shot.caption ?? title}
                    loading="lazy"
                    class="w-full h-auto"
                    style="border: 0.5px solid #E7E1D6;"
                  />
                  {shot.caption && (
                    <figcaption
                      class="font-sans text-[13px] mt-3"
                      style="color: #5A6167;"
                    >
                      {shot.caption}
                    </figcaption>
                  )}
                </figure>
              ))}
            </div>
          </div>
        )}

      </article>
    </main>

    <Footer />

    <!-- ── Prev / Next navigation ─────────────────────────────────────────── -->
    {(prevProject || nextProject) && (
      <nav
        class="bg-cream grid"
        style={`grid-template-columns: ${prevProject && nextProject ? '1fr 1fr' : '1fr'}; border-top: 0.5px solid #E7E1D6;`}
      >
        {prevProject && (
          <a href={`/work/${prevProject.id}`} class="group px-8 md:px-16 py-10 flex flex-col gap-2">
            <span class="eyebrow text-accent-green">← Previous</span>
            <span class="font-serif text-[22px] md:text-[26px] text-navy leading-tight group-hover:opacity-60 transition-opacity">
              {prevProject.data.title}
            </span>
            <span class="eyebrow" style="color: #A87C52; font-size: 10px;">{prevProject.data.tag}</span>
          </a>
        )}
        {nextProject && (
          <a
            href={`/work/${nextProject.id}`}
            class="group px-8 md:px-16 py-10 flex flex-col gap-2 items-end text-right"
            style={prevProject ? 'border-left: 0.5px solid #E7E1D6;' : ''}
          >
            <span class="eyebrow text-accent-green">Next →</span>
            <span class="font-serif text-[22px] md:text-[26px] text-navy leading-tight group-hover:opacity-60 transition-opacity">
              {nextProject.data.title}
            </span>
            <span class="eyebrow" style="color: #A87C52; font-size: 10px;">{nextProject.data.tag}</span>
          </a>
        )}
      </nav>
    )}

  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>
