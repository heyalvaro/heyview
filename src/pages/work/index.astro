---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WorkCard from '../../components/WorkCard.astro';

const projects = (await getCollection('work', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);

const featured = projects.find((p) => p.data.featured) ?? projects[0];
const rest = projects.filter((p) => p.id !== featured?.id);
---

<Layout
  title="Work — HeyView"
  description="Selected work from HeyView — design, automation, and AI systems for specialty practices and complex operations."
>
  <div class="max-w-360 mx-auto relative shadow-sm">
    <Navbar transition:persist />
    <main id="main-content">
      <section class="bg-navy px-5 md:px-16 py-24">

        <span class="eyebrow text-accent-green block mb-6">Selected Work</span>
        <h1 class="font-serif text-[40px] md:text-[56px] text-cream font-normal mb-4">The work.</h1>
        <p class="font-sans text-[17px] leading-relaxed max-w-2xl mb-16" style="color: rgba(245, 240, 232, 0.7);">
          A selection of projects across design, automation, and AI. Some engagements are
          confidential — reach out and we'll walk you through the details.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
          {featured && <WorkCard project={featured} variant="featured" class="col-span-1 md:col-span-12" />}
          {rest.map((project) => (
            <WorkCard project={project} variant="compact" class="col-span-1 md:col-span-6" />
          ))}
        </div>

      </section>
    </main>
    <Footer />
  </div>
</Layout>
